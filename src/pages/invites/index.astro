---
// Page liste des invités (artistes)
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArtisteCard from '../../components/ArtisteCard.astro';
import { getAllArtistes } from '../../../backend/backend.mjs';

// Récupérer tous les artistes depuis PocketBase
const artistes = await getAllArtistes();
---

<Layout title="Invités - Jumelages">

    <Header currentPage="invites" />
     
    <main class="pt-24 px-4 min-h-screen">
        <h1 class="text-5xl font-bold text-center text-[#ffee00] mb-12">Les Invités</h1>
        
        <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            
            {artistes.map((artiste) => (
                <ArtisteCard artiste={artiste} />
            ))}

            <!-- Message si aucun artiste -->
            {artistes.length === 0 && (
                <p class="text-gray-400 text-center col-span-3">
                    Aucun artiste pour le moment. La programmation arrive bientôt !
                </p>
            )}
            
        </div>
    </main>

    <Footer />

</Layout>
