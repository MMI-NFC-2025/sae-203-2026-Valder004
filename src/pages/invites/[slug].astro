---
// Route dynamique pour un artiste
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getAllArtistes } from '../../../backend/backend.mjs';

// Génération des pages statiques
export async function getStaticPaths() {
    try {
        const artistes = await getAllArtistes();
        console.log(`✓ PocketBase: ${artistes.length} routes générées pour [slug]`);
        
        return artistes.map((artiste) => ({
            params: { slug: artiste.slug || artiste.id },
            props: { artiste },
        }));
    } catch (error) {
        console.error('Erreur lors de la génération des pages statiques:', error);
        return [];
    }
}

// Récupérer l'artiste
const { slug } = Astro.params;
const { artiste } = Astro.props;

// Construire les URLs des images
const photoUrl = artiste?.photo 
    ? `http://127.0.0.1:8090/api/files/${artiste.id}/${artiste.photo}` 
    : null;

const galerieUrls = artiste?.galerie && Array.isArray(artiste.galerie) && artiste.galerie.length > 0 
    ? artiste.galerie.map(filename => `http://127.0.0.1:8090/api/files/${artiste.id}/${filename}`)
    : [];
---

<Layout title={`${artiste.Nom} - Jumelages`}>

    <Header currentPage="invites" />

    <main class="pt-24 px-4 min-h-screen">
        
        <!-- Bouton retour -->
        <div class="max-w-4xl mx-auto mb-8">
            <a href="/invites" class="text-[#000000] hover:underline">
                ← Retour aux invités
            </a>
        </div>

        <!-- Détails de l'artiste -->
        <div class="max-w-4xl mx-auto">

            <!-- Section photo principale -->
            {photoUrl && (
                <div class="mb-8 overflow-hidden rounded-lg bg-gray-900">
                    <img src={photoUrl} alt={artiste.Nom} class="w-full h-96 object-cover" />
                </div>
            )}

            <div class="bg-[#1a1a1a] p-8">
                
                <p class="text-[#e63946] text-lg mb-2">{artiste?.jour || artiste?.Date || 'À confirmer'}</p>
                <h1 class="text-5xl font-bold mb-4">{artiste?.Nom}</h1>
                <p class="text-[#f4a261] text-xl mb-6">{artiste?.genre || artiste?.Genre_musical || 'À confirmer'}</p>
                
                <div class="mb-6">
                    <p class="text-gray-300 text-lg">{artiste?.description || 'Aucune description disponible'}</p>
                </div>

                <!-- Infos supplémentaires -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-8 pt-8 border-t border-gray-700">
                    
                    <div>
                        <p class="text-gray-500 text-sm">Scène</p>
                        <p class="text-white text-lg">{artiste?.Scene || 'À confirmer'}</p>
                    </div>
                    
                    <div>
                        <p class="text-gray-500 text-sm">Horaire</p>
                        <p class="text-white text-lg">{artiste?.heure || 'À confirmer'}</p>
                    </div>
                    
                </div>

            </div>

            <!-- Section galerie -->
            {galerieUrls && galerieUrls.length > 0 && (
                <div class="mt-12">
                    <h2 class="text-3xl font-bold mb-6 text-[#e63946]">Galerie</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        {galerieUrls.map((url, index) => (
                            <div class="overflow-hidden rounded-lg bg-gray-900 hover:opacity-90 transition-opacity">
                                <img src={url} alt={`${artiste?.Nom || 'Artiste'} - Image ${index + 1}`} class="w-full h-64 object-cover" />
                            </div>
                        ))}
                    </div>
                </div>
            )}

        </div>

    </main>

    <Footer />

</Layout>
