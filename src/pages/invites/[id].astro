---
import PocketBase from 'pocketbase';
import Pbimg from '../../components/Pbimg.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Layout from '../../layouts/Layout.astro';
import Carousel from "../../components/Carousel.astro";

const pb = new PocketBase('http://127.0.0.1:8090');

const { id } = Astro.params;

// Récupération de l'artiste
const artiste = await pb.collection('Artiste').getOne(id);
---

<html lang="fr">
<Layout/>
<Header />

<body class="bg-[#1a1a1a] text-white p-6">

  <h1 class="text-3xl font-bold mt-4 pt-16">{artiste.nom}</h1>
  <p class="text-[#f4a261] text-lg mt-1">{artiste.genre_musical}</p>

  <!-- Image principale -->
  {artiste.photo && (
    <div class="mt-6 w-full max-w-xl">
      <Pbimg 
        record={artiste}
        imageName={artiste.photo}
        alt={artiste.nom}
        width="100%"
        height="auto"
        class="rounded-lg"
      />
    </div>
  )}

  <p class="mt-4 text-gray-300 leading-relaxed">
    {artiste.description}
  </p>

  <!-- CARROUSEL UNIQUEMENT -->
  {artiste.galerie?.length > 0 && (
    <Carousel 
      record={artiste}
      images={artiste.galerie}
      alt={`Galerie - ${artiste.nom}`}
    />
  )}

</body>
</html>
