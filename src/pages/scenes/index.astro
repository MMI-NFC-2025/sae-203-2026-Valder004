---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SceneCard from '../../components/SceneCard.astro';
import { getAllScenes } from '../../../backend/backend.mjs';

let Scenes = [];
try {
  Scenes = await getAllScenes();
  console.log("Scenes chargées :", Scenes);
} catch (error) {
  console.error("Erreur lors du chargement des scènes :", error);
}
---

<Layout title="Scènes - Jumelages">

  <Header currentPage="scenes" />

  <main class="pt-24 px-4 pb-16 min-h-screen">
    <div class="max-w-7xl mx-auto mb-16">
      <h1 class="text-5xl md:text-6xl font-bold text-center text-[#ffee00] mb-4">Les Scènes</h1>
      <p class="text-center text-gray-400 text-lg">Découvrez les lieux du festival Jumelages</p>
    </div>

    <div class="max-w-7xl mx-auto">
      {Scenes.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-max">
          {Scenes.filter(s => s).map((scene, index) => (
            <div
              class="animate-fadeIn"
              style={{ animationDelay: `${index * 0.1}s` }}
            >
              <SceneCard Scene={scene} />
            </div>
          ))}
        </div>
      ) : (
        <div class="col-span-full">
          <div class="border rounded-lg p-12 text-center">
            <p class="text-gray-400 text-lg">
              Aucune scène pour le moment.
            </p>
          </div>
        </div>
      )}
    </div>
  </main>

  <Footer />

</Layout>
