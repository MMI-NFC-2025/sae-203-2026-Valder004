---
// Page programme
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Programme - Jumelages">

    <Header currentPage="programme" />

    <main class="pt-24 px-4 min-h-screen">
        <h1 class="text-5xl font-bold text-center text-[#ffee00] mb-12">Programme</h1>
        
        <div class="max-w-4xl mx-auto">
            
            <!-- JOUR 1 -->
            <div class="mb-12">
                <h2 class="text-3xl font-bold text-[#f4a261] mb-6">Samedi 29 Août</h2>
                                <div class="bg-primary p-6 mb-4">
                    <p class="text-gray-400">18h00 - OUVERTURE</p>

                </div>                
                <div class="bg-primary p-6 mb-4">
                    <p class="text-gray-400">19h00 - Le Kiosque</p>
                    <p class="text-xl font-bold">Dis'cover</p>
                </div>
                    <div class="bg-primary p-6 mb-4">
                    <p class="text-gray-400">20h00 - Le Pavillon</p>
                    <p class="text-xl font-bold">City Zen Kane</p>
                </div>

                <div class="bg-primary p-6 mb-4">
                    <p class="text-gray-400">21h00 - Le Kiosque</p>
                    <p class="text-xl font-bold">Laura Joan</p>
                </div>
                
                <div class="bg-primary p-6 mb-4">
                    <p class="text-gray-400">22h00 - Le Pavillon</p>
                    <p class="text-xl font-bold">Norah Jones</p>
                </div>
                
                <div class="bg-primary p-6">
                    <p class="text-gray-400">23h00 - Le Kiosque</p>
                    <p class="text-xl font-bold">Angus & Julia Stone</p>
                </div>
            </div>
            
            <!-- JOUR 2 -->
            <div class="mb-12">
                <h2 class="text-3xl font-bold text-[#f4a261] mb-6">Dimanche 30 Août</h2>
                
                <div class="bg-primary p-6 mb-4">
                    <p class="text-gray-400">18h00 - OUVERTURE</p>
                </div>
                
                <div class="bg-primary p-6 mb-4">
                    <p class="text-gray-400">19h00 - Le Kiosque</p>
                    <p class="text-xl font-bold">Ben Howard</p>
                </div>
                
                <div class="bg-primary p-6 mb-4">
                    <p class="text-gray-400">20h00 - Le Pavillon</p>
                    <p class="text-xl font-bold">Passenger</p>
                </div>
                
                <div class="bg-primary p-6 mb-4">
                    <p class="text-gray-400">21h00 - Le Kiosque</p>
                    <p class="text-xl font-bold">Vance Joy</p>
                </div>
                
                <div class="bg-primary p-6">
                    <p class="text-gray-400">22h00 - Le Pavillon</p>
                    <p class="text-xl font-bold">Jack Johnson</p>
                </div>
            </div>
            
        </div>
    </main>

    <Footer />

</Layout>
