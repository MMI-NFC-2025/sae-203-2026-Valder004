---
// Page programme
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Programme - Jumelages">

    <Header currentPage="programme" />

    <main class="pt-24 px-4 min-h-screen">
        <h1 class="text-5xl font-bold text-center text-[#ffee00] mb-12">Programme</h1>
        
        <div class="max-w-4xl mx-auto">
            
            <!-- JOUR 1 -->
            <div class="mb-12">
                <h2 class="text-3xl font-bold text-[#f4a261] mb-6">Samedi 29 Août</h2>
                
                <div class="bg-[#1a1a1a] p-6 mb-4">
                    <p class="text-gray-400">14h00 - Le Kiosque</p>
                    <p class="text-xl font-bold">Ouverture des portes</p>
                </div>
                
                <div class="bg-[#1a1a1a] p-6 mb-4">
                    <p class="text-gray-400">15h00 - Le Kiosque</p>
                    <p class="text-xl font-bold">DJ Set d'ouverture</p>
                </div>
                
                <div class="bg-[#1a1a1a] p-6 mb-4">
                    <p class="text-gray-400">17h00 - Le Pavillon</p>
                    <p class="text-xl font-bold">Groupe Local</p>
                </div>
                
                <div class="bg-[#1a1a1a] p-6 mb-4">
                    <p class="text-gray-400">19h00 - Le Kiosque</p>
                    <p class="text-xl font-bold">Artiste Invité</p>
                </div>
                
                <div class="bg-[#1a1a1a] p-6">
                    <p class="text-gray-400">21h00 - Le Pavillon</p>
                    <p class="text-xl font-bold">Tête d'affiche</p>
                </div>
            </div>
            
            <!-- JOUR 2 -->
            <div class="mb-12">
                <h2 class="text-3xl font-bold text-[#f4a261] mb-6">Dimanche 30 Août</h2>
                
                <div class="bg-[#1a1a1a] p-6 mb-4">
                    <p class="text-gray-400">14h00</p>
                    <p class="text-xl font-bold">Ouverture des portes</p>
                </div>
                
                <div class="bg-[#1a1a1a] p-6 mb-4">
                    <p class="text-gray-400">15h30 - Le Kiosque</p>
                    <p class="text-xl font-bold">Collectif Musical</p>
                </div>
                
                <div class="bg-[#1a1a1a] p-6 mb-4">
                    <p class="text-gray-400">17h30 - Le Pavillon</p>
                    <p class="text-xl font-bold">Artiste Surprise</p>
                </div>
                
                <div class="bg-[#1a1a1a] p-6 mb-4">
                    <p class="text-gray-400">19h30 - Le Kiosque</p>
                    <p class="text-xl font-bold">Performance Live</p>
                </div>
                
                <div class="bg-[#1a1a1a] p-6">
                    <p class="text-gray-400">21h30 - Le Pavillon</p>
                    <p class="text-xl font-bold">Grand Final</p>
                </div>
            </div>
            
        </div>
    </main>

    <Footer />

</Layout>
