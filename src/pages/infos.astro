---
// Page infos pratiques
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Infos pratiques - Jumelages">

    <Header currentPage="infos" />

    <main class="pt-24 px-4 min-h-screen">
        <h1 class="text-5xl font-bold text-center text-[#ffee00] mb-12">Infos pratiques</h1>
        
        <div class="max-w-4xl mx-auto">
            
            <!-- Infos en grille -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
                
                <!-- Dates -->
                <div class="bg-[#1100ae] p-6">
                    <h3 class="text-xl font-bold text-[#f4a261] mb-4">Dates</h3>
                    <p class="text-white">29 et 30 août 2025</p>
                    <p class="text-gray-400">Ouverture des portes à 14h00</p>
                </div>
                
                <!-- Lieu -->
                <div class="bg-[#1a1a1a] p-6">
                    <h3 class="text-xl font-bold text-[#f4a261] mb-4">Lieu</h3>
                    <p class="text-white">Parc de la Ville</p>
                    <p class="text-gray-400">Place du Festival</p>
                    <p class="text-gray-400">25000 Besançon</p>
                </div>
                
                <!-- Tarifs -->
                <div class="bg-[#1a1a1a] p-6">
                    <h3 class="text-xl font-bold text-[#f4a261] mb-4">Tarifs</h3>
                    <p class="text-white">Pass 1 jour : 25€</p>
                    <p class="text-white">Pass 2 jours : 40€</p>
                    <p class="text-gray-400">Gratuit pour les moins de 12 ans</p>
                </div>
                
                <!-- Accès -->
                <div class="bg-[#1a1a1a] p-6">
                    <h3 class="text-xl font-bold text-[#f4a261] mb-4">Accès</h3>
                    <p class="text-white">Tramway : Ligne 1, arrêt Festival</p>
                    <p class="text-white">Bus : Lignes 3, 7, 12</p>
                    <p class="text-gray-400">Parking gratuit à proximité</p>
                </div>
                
            </div>
            
            <!-- FAQ -->
            <div class="mb-12">
                <h2 class="text-3xl font-bold text-[#f4a261] mb-6">Questions fréquentes</h2>
                
                <div class="bg-[#1a1a1a] p-6 mb-4">
                    <h3 class="font-bold mb-2">Puis-je apporter ma propre nourriture ?</h3>
                    <p class="text-gray-400">Non, des stands de restauration seront présents sur place.</p>
                </div>
                
                <div class="bg-[#1a1a1a] p-6 mb-4">
                    <h3 class="font-bold mb-2">Le festival est-il accessible aux personnes à mobilité réduite ?</h3>
                    <p class="text-gray-400">Oui, le site est entièrement accessible.</p>
                </div>
                
                <div class="bg-[#1a1a1a] p-6 mb-4">
                    <h3 class="font-bold mb-2">Y a-t-il un vestiaire ?</h3>
                    <p class="text-gray-400">Oui, un vestiaire est disponible pour 3€.</p>
                </div>
                
                <div class="bg-[#1a1a1a] p-6">
                    <h3 class="font-bold mb-2">Les animaux sont-ils autorisés ?</h3>
                    <p class="text-gray-400">Non, sauf les chiens guides.</p>
                </div>
            </div>
            
            <!-- Contact -->
            <div class="text-center bg-[#1a1a1a] p-8">
                <h2 class="text-2xl font-bold mb-4">Une question ?</h2>
                <p class="text-gray-400 mb-4">Contactez-nous :</p>
                <a href="mailto:contact@jumelages.fr" class="text-[#e63946] text-xl">contact@jumelages.fr</a>
            </div>
            
        </div>
    </main>

    <Footer />

</Layout>
