---
import { getImageUrl } from '../../backend/backend.mjs';

const { record, imageName, alt = 'Image', width = '100%', height = 'auto' } = Astro.props;

const imageURL = getImageUrl(record, imageName);
---

{imageURL && 
    <img
        src={imageURL}
        alt={alt || record?.Nom || 'Image'}
        style={`width: ${width}; height: ${height}; object-fit: cover;`}
        class="rounded transition-transform hover:scale-105"
    />
}