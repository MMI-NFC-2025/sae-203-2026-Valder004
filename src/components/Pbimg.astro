---
import { getImageUrl } from '../../backend/backend.mjs';

interface Props {
    record: any;
    imageName: string; // obligatoire pour éviter les ambiguïtés
    alt?: string;
    width?: string;
    height?: string;
    class?: string;
}

const { 
    record, 
    imageName,
    alt = 'Image', 
    width = '100%', 
    height = 'auto', 
    class: className 
} = Astro.props as Props;

const imageURL = getImageUrl(record, imageName);
---

{imageURL && 
    <img
        src={imageURL}
        alt={alt}
        style={`width: ${width}; height: ${height}; object-fit: cover;`}
        class={className || "rounded transition-transform hover:scale-105"}
    />
}
