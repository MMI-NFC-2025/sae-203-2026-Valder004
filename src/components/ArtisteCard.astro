---
const { Artiste } = Astro.props;
const lien = `/invites/${Artiste.slug || Artiste.id}`;
---

<a href={lien} class="block bg-[#1a1a1a] p-4 md:p-6 hover:bg-[#252525] transition-colors">
    <p class="text-[#e63946] text-xs md:text-sm mb-2">{Artiste.jour}</p>
    <h3 class="text-lg md:text-xl font-bold mb-2">{Artiste.nom}</h3>
    <p class="text-[#f4a261] text-xs md:text-sm mb-2">{Artiste.genre}</p>
    <p class="text-gray-400 text-xs md:text-sm">{Artiste.description}</p>
</a>
